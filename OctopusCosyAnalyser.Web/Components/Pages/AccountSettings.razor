@page "/settings"
@inject HeatPumpApiClient Api
@rendermode InteractiveServer
@using OctopusCosyAnalyser.Shared.Models

<PageTitle>Account Settings</PageTitle>

<h1>Account Settings</h1>

@if (isLoading)
{
    <div class="d-flex align-items-center mt-3">
        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
        <span>Loading settings...</span>
    </div>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title mb-3">Octopus Energy</h5>
            <div class="mb-3">
                <label class="form-label">Account Number</label>
                <input @bind="accountNumber" class="form-control" placeholder="A-1234-5678" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input @bind="email" type="email" class="form-control" placeholder="your@email.com" />
                <div class="form-text">The email address you use to log in to Octopus Energy.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input @bind="octopusPassword" type="password" class="form-control" />
                <div class="form-text">Your Octopus Energy account password. Used for GraphQL API authentication.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">API Key <span class="text-muted">(optional)</span></label>
                <input @bind="apiKey" type="password" class="form-control" placeholder="sk_live_..." />
                <div class="form-text">Only needed for smart meter consumption data. Found at <a href="https://octopus.energy/dashboard/new/accounts/personal-details/api-access" target="_blank">octopus.energy/dashboard</a>.</div>
            </div>

            <h5 class="card-title mb-3 mt-4">AI Analysis</h5>
            <div class="mb-3">
                <label class="form-label">Anthropic API Key <span class="text-muted">(optional)</span></label>
                <input @bind="anthropicApiKey" type="password" class="form-control" placeholder="sk-ant-..." />
                <div class="form-text">Required for the AI Analysis feature. Get a key at <a href="https://console.anthropic.com/settings/keys" target="_blank">console.anthropic.com</a>.</div>
            </div>

            <button @onclick="SaveSettings" class="btn btn-primary" disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>Save Settings</span>
                }
            </button>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                var alertClass = statusMessage.StartsWith("Settings saved") ? "alert-success" : "alert-info";
                <div class="alert @alertClass mt-3">@statusMessage</div>
            }
        </div>
    </div>
}

@code {
    private string accountNumber = string.Empty;
    private string email = string.Empty;
    private string octopusPassword = string.Empty;
    private string apiKey = string.Empty;
    private string anthropicApiKey = string.Empty;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await Api.GetSettingsAsync();
            var current = settings.FirstOrDefault();
            if (current is not null)
            {
                accountNumber = current.AccountNumber;
                email = current.Email ?? string.Empty;
                octopusPassword = current.OctopusPassword ?? string.Empty;
                apiKey = current.ApiKey;
                anthropicApiKey = current.AnthropicApiKey ?? string.Empty;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        if (string.IsNullOrWhiteSpace(accountNumber) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(octopusPassword))
        {
            statusMessage = "Account number, email, and password are required.";
            return;
        }

        isSaving = true;
        statusMessage = null;

        try
        {
            var result = await Api.UpsertSettingsAsync(new AccountSettingsRequestDto
            {
                AccountNumber = accountNumber.Trim(),
                Email = email.Trim(),
                OctopusPassword = octopusPassword.Trim(),
                ApiKey = string.IsNullOrWhiteSpace(apiKey) ? null : apiKey.Trim(),
                AnthropicApiKey = string.IsNullOrWhiteSpace(anthropicApiKey) ? null : anthropicApiKey.Trim()
            });

            statusMessage = result != null ? "Settings saved." : "Save failed.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
