@inject HeatPumpApiClient Api
@rendermode InteractiveServer

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (string.IsNullOrEmpty(AccountNumber))
{
    <div class="alert alert-info">Account not set. Set up your device from the dashboard first.</div>
}
else
{
    <div class="row g-3 align-items-end mb-3 mt-2">
        <div class="col-md-2">
            <label class="form-label">From</label>
            <input @bind="fromDate" type="datetime-local" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label">To</label>
            <input @bind="toDate" type="datetime-local" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary btn-sm w-100" @onclick="LoadData" disabled="@isLoading">
                @(isLoading ? "Loading..." : "Load Data")
            </button>
        </div>
        <div class="col-md-4">
            <div class="btn-group btn-group-sm w-100">
                <button class="btn btn-outline-secondary" @onclick="() => SetRange(1)">1 Day</button>
                <button class="btn btn-outline-secondary" @onclick="() => SetRange(7)">7 Days</button>
                <button class="btn btn-outline-secondary" @onclick="() => SetRange(30)">30 Days</button>
                <button class="btn btn-outline-secondary" @onclick="() => SetRange(90)">90 Days</button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info py-1 small">@statusMessage</div>
    }

    @if (costLoaded)
    {
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="card text-center"><div class="card-body">
                    <h6 class="card-subtitle text-muted">Total Cost (inc. tax)</h6>
                    <h3 class="card-title">@FormatPence(totalCostInclTax)</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card text-center"><div class="card-body">
                    <h6 class="card-subtitle text-muted">Total Usage</h6>
                    <h3 class="card-title">@totalUsageKwh.ToString("F1") kWh</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card text-center"><div class="card-body">
                    <h6 class="card-subtitle text-muted">Avg Daily Cost</h6>
                    <h3 class="card-title">@FormatPence(avgDailyCost)</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card text-center"><div class="card-body">
                    <h6 class="card-subtitle text-muted">Avg Unit Rate</h6>
                    <h3 class="card-title">@(totalUsageKwh > 0 ? (totalCostInclTax / totalUsageKwh * 100).ToString("F2") : "—") p/kWh</h3>
                </div></div>
            </div>
        </div>

        @if (costRates.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header"><strong>Cost by Rate Period</strong></div>
                <div class="card-body">
                    <RadzenChart Style="height: 350px">
                        <RadzenColumnSeries Data="@costRates" CategoryProperty="Label" ValueProperty="CostInclTax" Title="Cost (p)" Fill="#ff6600" />
                        <RadzenCategoryAxis><RadzenGridLines Visible="true" /></RadzenCategoryAxis>
                        <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                    </RadzenChart>
                </div>
            </div>
        }
    }

    @if (ratesLoaded && applicableRates.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Tariff Rates</strong></div>
            <div class="card-body">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-striped">
                        <thead class="table-light sticky-top">
                            <tr><th>Valid From</th><th>Valid To</th><th class="text-end">Rate (p/kWh)</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var rate in applicableRates)
                            {
                                <tr><td>@rate.ValidFrom</td><td>@rate.ValidTo</td><td class="text-end">@rate.Value.ToString("F4")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? AccountNumber { get; set; }

    private string? errorMessage;
    private string? statusMessage;
    private bool isLoading, costLoaded, ratesLoaded;
    private DateTime fromDate = DateTime.UtcNow.AddDays(-7);
    private DateTime toDate = DateTime.UtcNow;

    private double totalCostInclTax, totalUsageKwh, avgDailyCost;
    private List<CostRatePoint> costRates = [];
    private List<TariffRatePoint> applicableRates = [];

    private void SetRange(int days) { toDate = DateTime.UtcNow; fromDate = DateTime.UtcNow.AddDays(-days); }

    private async Task LoadData()
    {
        if (string.IsNullOrEmpty(AccountNumber)) return;
        isLoading = true; statusMessage = "Loading cost data..."; costLoaded = false; ratesLoaded = false;
        try
        {
            await LoadCostOfUsage();
            await LoadApplicableRates();
            statusMessage = costLoaded ? "Data loaded." : "Could not load cost data.";
        }
        catch (Exception ex) { statusMessage = $"Error: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task LoadCostOfUsage()
    {
        try
        {
            var raw = await Api.GetCostOfUsageRawAsync(AccountNumber!, fromDate, toDate);
            var doc = System.Text.Json.JsonDocument.Parse(raw);
            var root = doc.RootElement.GetProperty("data");
            if (root.TryGetProperty("costOfUsage", out var costEl) && costEl.ValueKind != System.Text.Json.JsonValueKind.Null
                && costEl.TryGetProperty("edges", out var edgesEl) && edgesEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                costRates.Clear(); double totalCost = 0, totalUsage = 0; int idx = 0;
                foreach (var edge in edgesEl.EnumerateArray())
                {
                    if (!edge.TryGetProperty("node", out var node)) continue; idx++;
                    var startAt = node.TryGetProperty("startAt", out var sa) ? sa.GetString() : null;
                    var label = startAt != null && DateTime.TryParse(startAt, out var dt) ? dt.ToLocalTime().ToString("MMM dd HH:mm") : $"Period {idx}";
                    var cost = GetDouble(node, "costInclTax"); var usage = GetDouble(node, "consumptionKwh");
                    totalCost += cost; totalUsage += usage;
                    costRates.Add(new() { Label = label, CostInclTax = cost, UsageKwh = usage });
                }
                totalCostInclTax = totalCost; totalUsageKwh = totalUsage;
                avgDailyCost = (toDate - fromDate).TotalDays > 0 ? totalCostInclTax / (toDate - fromDate).TotalDays : 0;
                costLoaded = true;
            }
        }
        catch { }
    }

    private async Task LoadApplicableRates()
    {
        try
        {
            var raw = await Api.GetApplicableRatesRawAsync(AccountNumber!, fromDate, toDate);
            applicableRates.Clear();
            var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("data", out var dataEl) && dataEl.TryGetProperty("applicableRates", out var ratesEl)
                && ratesEl.ValueKind == System.Text.Json.JsonValueKind.Object && ratesEl.TryGetProperty("edges", out var edgesEl))
            {
                foreach (var edge in edgesEl.EnumerateArray())
                {
                    if (!edge.TryGetProperty("node", out var node)) continue;
                    applicableRates.Add(new()
                    {
                        ValidFrom = FmtIso(node.TryGetProperty("validFrom", out var vf) ? vf.GetString() ?? "" : ""),
                        ValidTo = FmtIso(node.TryGetProperty("validTo", out var vt) ? vt.GetString() ?? "" : ""),
                        Value = GetDouble(node, "value")
                    });
                }
            }
            ratesLoaded = true;
        }
        catch { ratesLoaded = true; }
    }

    private static double GetDouble(System.Text.Json.JsonElement el, string prop)
    {
        if (!el.TryGetProperty(prop, out var val)) return 0;
        if (val.ValueKind == System.Text.Json.JsonValueKind.Number && val.TryGetDouble(out var d)) return d;
        if (val.ValueKind == System.Text.Json.JsonValueKind.String && double.TryParse(val.GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var p)) return p;
        return 0;
    }

    private static string FmtIso(string iso) => DateTimeOffset.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.RoundtripKind, out var dto) ? dto.ToLocalTime().ToString("dd MMM HH:mm") : iso;
    private static string FormatPence(double p) => p >= 100 ? $"\u00a3{(p / 100):F2}" : $"{p:F1}p";

    private sealed class CostRatePoint { public string Label { get; set; } = ""; public double CostInclTax { get; set; } public double UsageKwh { get; set; } }
    private sealed class TariffRatePoint { public string ValidFrom { get; set; } = ""; public string ValidTo { get; set; } = ""; public double Value { get; set; } }
}
