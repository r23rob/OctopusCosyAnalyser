@inject HeatPumpApiClient Api
@rendermode InteractiveServer
@using OctopusCosyAnalyser.Web.Services

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<RadzenTabs>
    <Tabs>
        <!-- Insights Sub-Tab -->
        <RadzenTabsItem Text="Efficiency Insights" Icon="lightbulb">
            <div class="row g-3 mb-3 mt-2">
                <div class="col-md-2">
                    <label class="form-label">From</label>
                    <input @bind="insightsFrom" type="datetime-local" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">To</label>
                    <input @bind="insightsTo" type="datetime-local" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary btn-sm w-100" @onclick="LoadInsights" disabled="@insightsLoading">
                        @(insightsLoading ? "Loading..." : "Load Data")
                    </button>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" @onclick="() => { insightsTo = DateTime.UtcNow; insightsFrom = DateTime.UtcNow.AddDays(-7); }">7d</button>
                        <button class="btn btn-outline-secondary" @onclick="() => { insightsTo = DateTime.UtcNow; insightsFrom = DateTime.UtcNow.AddDays(-30); }">30d</button>
                        <button class="btn btn-outline-secondary" @onclick="() => { insightsTo = DateTime.UtcNow; insightsFrom = DateTime.UtcNow.AddDays(-90); }">90d</button>
                    </div>
                </div>
            </div>

            @if (recommendations.Count > 0)
            {
                <div class="card mb-3 border-warning">
                    <div class="card-header bg-warning bg-opacity-10"><strong>Quick Recommendations</strong></div>
                    <div class="card-body">
                        <ul class="mb-0">@foreach (var rec in recommendations) { <li>@rec</li> }</ul>
                    </div>
                </div>
            }

            @if (insightsSnapshots.Count > 0)
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header">COP vs Outdoor Temperature</div>
                            <div class="card-body">
                                <RadzenChart Style="height: 280px;">
                                    <RadzenLineSeries Data="@copVsOutdoor" CategoryProperty="X" ValueProperty="Y" Title="COP" Stroke="rgba(40,167,69,0.6)" StrokeWidth="2" />
                                    <RadzenLineSeries Data="@cop3RefLine" CategoryProperty="X" ValueProperty="Y" Title="COP = 3.0" Stroke="rgb(220,53,69)" StrokeWidth="1" />
                                    <RadzenCategoryAxis />
                                    <RadzenValueAxis Min="0"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                                </RadzenChart>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header">COP vs Flow Temperature</div>
                            <div class="card-body">
                                <RadzenChart Style="height: 280px;">
                                    <RadzenLineSeries Data="@copVsFlow" CategoryProperty="X" ValueProperty="Y" Title="COP" Stroke="rgba(0,123,255,0.6)" StrokeWidth="2" />
                                    <RadzenLineSeries Data="@cop3RefLineFlow" CategoryProperty="X" ValueProperty="Y" Title="COP = 3.0" Stroke="rgb(220,53,69)" StrokeWidth="1" />
                                    <RadzenCategoryAxis />
                                    <RadzenValueAxis Min="0"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                                    <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                                </RadzenChart>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">Room Temperature vs Setpoint vs Outdoor</div>
                    <div class="card-body">
                        <RadzenChart Style="height: 300px;">
                            <RadzenLineSeries Data="@roomTempOverTime" CategoryProperty="Time" ValueProperty="RoomTemp" Title="Room Temp (°C)" Stroke="rgb(40,167,69)" StrokeWidth="2" />
                            <RadzenLineSeries Data="@roomTempOverTime" CategoryProperty="Time" ValueProperty="Setpoint" Title="Setpoint (°C)" Stroke="rgb(255,193,7)" StrokeWidth="2" />
                            <RadzenLineSeries Data="@roomTempOverTime" CategoryProperty="Time" ValueProperty="OutdoorTemp" Title="Outdoor Temp (°C)" Stroke="rgb(173,216,230)" StrokeWidth="2" />
                            <RadzenCategoryAxis FormatString="{0:MMM dd HH:mm}" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                </div>

                <!-- Duty Cycle -->
                <div class="card mb-3">
                    <div class="card-header"><strong>Heating Duty Cycle</strong></div>
                    <div class="card-body">
                        <p class="mb-2">
                            Overall duty cycle: <strong>@dutyCyclePercent.ToString("F1")%</strong>
                            @if (dutyCyclePercent > 80) { <span class="badge bg-danger ms-2">High</span> }
                            else if (dutyCyclePercent < 30) { <span class="badge bg-info ms-2">Low</span> }
                            else { <span class="badge bg-success ms-2">Normal</span> }
                        </p>
                        @if (dutyCycleByPeriod.Count > 0)
                        {
                            <table class="table table-bordered table-sm mb-0">
                                <thead><tr><th>Time of Day</th><th>Snapshots</th><th>Active</th><th>Duty Cycle</th></tr></thead>
                                <tbody>
                                    @foreach (var row in dutyCycleByPeriod)
                                    {
                                        <tr><td>@row.Period</td><td>@row.Total</td><td>@row.Active</td><td>@row.DutyCycle.ToString("F1")%</td></tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
        </RadzenTabsItem>

        <!-- Compare Sub-Tab -->
        <RadzenTabsItem Text="Compare Periods" Icon="compare_arrows">
            <div class="row g-3 mb-3 mt-2">
                <div class="col-md-6">
                    <div class="card compare-card compare-card-a">
                        <div class="card-header compare-header-a"><strong>Period A — Baseline</strong></div>
                        <div class="card-body">
                            <div class="row g-2 align-items-end">
                                <div class="col-6">
                                    <label class="form-label small">From</label>
                                    <input @bind="fromA" type="datetime-local" class="form-control form-control-sm" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">To</label>
                                    <input @bind="toA" type="datetime-local" class="form-control form-control-sm" />
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm w-100 mt-2">
                                <button class="btn btn-outline-primary" @onclick="() => { toA = fromB; fromA = toA.AddDays(-1); }">1d</button>
                                <button class="btn btn-outline-primary" @onclick="() => { toA = fromB; fromA = toA.AddDays(-7); }">7d</button>
                                <button class="btn btn-outline-primary" @onclick="() => { toA = fromB; fromA = toA.AddDays(-30); }">30d</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card compare-card compare-card-b">
                        <div class="card-header compare-header-b"><strong>Period B — After Change</strong></div>
                        <div class="card-body">
                            <div class="row g-2 align-items-end">
                                <div class="col-6">
                                    <label class="form-label small">From</label>
                                    <input @bind="fromB" type="datetime-local" class="form-control form-control-sm" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">To</label>
                                    <input @bind="toB" type="datetime-local" class="form-control form-control-sm" />
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm w-100 mt-2">
                                <button class="btn btn-outline-danger" @onclick="() => { toB = DateTime.UtcNow; fromB = toB.AddDays(-1); }">1d</button>
                                <button class="btn btn-outline-danger" @onclick="() => { toB = DateTime.UtcNow; fromB = toB.AddDays(-7); }">7d</button>
                                <button class="btn btn-outline-danger" @onclick="() => { toB = DateTime.UtcNow; fromB = toB.AddDays(-30); }">30d</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mb-4">
                <button class="btn btn-primary px-4" @onclick="LoadComparison" disabled="@compareLoading">
                    @(compareLoading ? "Comparing..." : "Compare Periods")
                </button>
            </div>

            @if (hasCompareData)
            {
                <div class="row g-3 mb-4">
                    @foreach (var metric in deltaMetrics)
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="card h-100 delta-card @(metric.IsImprovement ? "delta-positive" : metric.IsNeutral ? "" : "delta-negative")">
                                <div class="card-body text-center p-2">
                                    <div class="small text-muted mb-1">@metric.Label</div>
                                    <div class="d-flex justify-content-between px-1">
                                        <span class="compare-value-a small">@metric.ValueA</span>
                                        <span class="compare-value-b small">@metric.ValueB</span>
                                    </div>
                                    <div class="delta-value mt-1">
                                        @if (!metric.IsNeutral)
                                        {
                                            <span class="@(metric.IsImprovement ? "text-success" : "text-danger")">
                                                @(metric.DeltaValue > 0 ? "+" : "")@metric.DeltaFormatted @metric.Unit
                                            </span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </div>
                                    @if (metric.DeltaPercent.HasValue && !metric.IsNeutral)
                                    {
                                        <div class="small @(metric.IsImprovement ? "text-success" : "text-danger")">
                                            @(metric.DeltaPercent > 0 ? "+" : "")@metric.DeltaPercent?.ToString("F1")%
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>COP Comparison</strong></div>
                    <div class="card-body">
                        <RadzenChart Style="height: 320px;">
                            <RadzenLineSeries Data="@copChartA" CategoryProperty="ElapsedHours" ValueProperty="Value" Title="Period A" Stroke="rgba(59,130,246,0.8)" StrokeWidth="2" />
                            <RadzenLineSeries Data="@copChartB" CategoryProperty="ElapsedHours" ValueProperty="Value" Title="Period B" Stroke="rgba(239,68,68,0.8)" StrokeWidth="2" />
                            <RadzenCategoryAxis FormatString="{0:F0}h" />
                            <RadzenValueAxis Min="0"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                </div>
            }
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    [Parameter] public string? DeviceId { get; set; }

    private string? errorMessage;
    private bool _loaded;

    // Insights
    private bool insightsLoading;
    private DateTime insightsFrom = DateTime.UtcNow.AddDays(-7);
    private DateTime insightsTo = DateTime.UtcNow;
    private List<HeatPumpSnapshotDto> insightsSnapshots = [];
    private List<ScatterPoint> copVsOutdoor = [], cop3RefLine = [], copVsFlow = [], cop3RefLineFlow = [];
    private List<TimePoint> roomTempOverTime = [];
    private List<string> recommendations = [];
    private double dutyCyclePercent;
    private List<DutyCycleRow> dutyCycleByPeriod = [];

    // Compare
    private bool compareLoading;
    private bool hasCompareData;
    private DateTime fromA = DateTime.UtcNow.AddDays(-14), toA = DateTime.UtcNow.AddDays(-7);
    private DateTime fromB = DateTime.UtcNow.AddDays(-7), toB = DateTime.UtcNow;
    private List<DeltaMetric> deltaMetrics = [];
    private List<ElapsedPoint> copChartA = [], copChartB = [];

    protected override async Task OnParametersSetAsync()
    {
        if (_loaded || string.IsNullOrEmpty(DeviceId)) return;
        _loaded = true;
        await LoadInsights();
    }

    private async Task LoadInsights()
    {
        if (string.IsNullOrEmpty(DeviceId)) return;
        insightsLoading = true;
        try
        {
            var result = await Api.GetSnapshotsAsync(DeviceId, insightsFrom, insightsTo);
            insightsSnapshots = result?.Snapshots ?? [];
            BuildInsightCharts();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { insightsLoading = false; }
    }

    private void BuildInsightCharts()
    {
        copVsOutdoor = insightsSnapshots.Where(s => s.CoefficientOfPerformance.HasValue && s.OutdoorTemperatureCelsius.HasValue)
            .Select(s => new ScatterPoint { X = (double)s.OutdoorTemperatureCelsius!.Value, Y = (double)s.CoefficientOfPerformance!.Value }).ToList();
        cop3RefLine = BuildRefLine(copVsOutdoor, 3.0);

        copVsFlow = insightsSnapshots.Where(s => s.CoefficientOfPerformance.HasValue && s.HeatingFlowTemperatureCelsius.HasValue)
            .Select(s => new ScatterPoint { X = (double)s.HeatingFlowTemperatureCelsius!.Value, Y = (double)s.CoefficientOfPerformance!.Value }).ToList();
        cop3RefLineFlow = BuildRefLine(copVsFlow, 3.0);

        roomTempOverTime = insightsSnapshots.Where(s => s.RoomTemperatureCelsius.HasValue && s.HeatingZoneSetpointCelsius.HasValue)
            .Select(s => new TimePoint
            {
                Time = s.SnapshotTakenAt,
                RoomTemp = (double)s.RoomTemperatureCelsius!.Value,
                Setpoint = (double)s.HeatingZoneSetpointCelsius!.Value,
                OutdoorTemp = s.OutdoorTemperatureCelsius.HasValue ? (double)s.OutdoorTemperatureCelsius.Value : 0
            }).OrderBy(p => p.Time).ToList();

        // Duty cycle
        var withDemand = insightsSnapshots.Where(s => s.HeatingZoneHeatDemand.HasValue).ToList();
        dutyCyclePercent = withDemand.Count > 0 ? withDemand.Count(s => s.HeatingZoneHeatDemand == true) * 100.0 / withDemand.Count : 0;
        dutyCycleByPeriod = [];
        if (withDemand.Count >= 4)
        {
            dutyCycleByPeriod.Add(BuildDCRow("Morning (6-12)", withDemand, 6, 12));
            dutyCycleByPeriod.Add(BuildDCRow("Afternoon (12-18)", withDemand, 12, 18));
            dutyCycleByPeriod.Add(BuildDCRow("Evening (18-24)", withDemand, 18, 24));
            dutyCycleByPeriod.Add(BuildDCRow("Night (0-6)", withDemand, 0, 6));
        }

        // Recommendations
        recommendations = [];
        var keepingTemp = roomTempOverTime.Where(p => p.RoomTemp >= p.Setpoint - 0.5).ToList();
        var keepingCop = insightsSnapshots.Where(s => s.CoefficientOfPerformance.HasValue && s.RoomTemperatureCelsius.HasValue && s.HeatingZoneSetpointCelsius.HasValue
            && (double)s.RoomTemperatureCelsius.Value >= (double)s.HeatingZoneSetpointCelsius.Value - 0.5)
            .Select(s => (double)s.CoefficientOfPerformance!.Value).ToList();
        if (keepingCop.Count > 0 && keepingCop.Average() < 3.0) recommendations.Add("Consider lowering your WC max flow temperature to improve efficiency.");
        if (dutyCyclePercent > 80) recommendations.Add("Your system is running almost continuously. Your WC min may be too low for very cold days.");
        if (dutyCyclePercent > 0 && dutyCyclePercent < 30) recommendations.Add("Your system has headroom. Consider lowering your setpoint by 0.5°C to save energy.");
    }

    private async Task LoadComparison()
    {
        if (string.IsNullOrEmpty(DeviceId)) return;
        compareLoading = true; hasCompareData = false;
        try
        {
            var taskA = Api.GetSnapshotsAsync(DeviceId, fromA, toA);
            var taskB = Api.GetSnapshotsAsync(DeviceId, fromB, toB);
            await Task.WhenAll(taskA, taskB);
            var snapsA = taskA.Result?.Snapshots ?? [];
            var snapsB = taskB.Result?.Snapshots ?? [];
            if (snapsA.Count == 0 && snapsB.Count == 0) return;

            deltaMetrics =
            [
                BuildDelta("Avg COP", "", "F2", AvgDec(snapsA, s => s.CoefficientOfPerformance), AvgDec(snapsB, s => s.CoefficientOfPerformance), true),
                BuildDelta("Avg Outdoor", "°C", "F1", AvgDec(snapsA, s => s.OutdoorTemperatureCelsius), AvgDec(snapsB, s => s.OutdoorTemperatureCelsius), false, true),
                BuildDelta("Avg Power In", "kW", "F2", AvgDec(snapsA, s => s.PowerInputKilowatt), AvgDec(snapsB, s => s.PowerInputKilowatt), false),
                BuildDelta("Total Energy In", "kWh", "F1", TotalEnergy(snapsA, s => s.PowerInputKilowatt), TotalEnergy(snapsB, s => s.PowerInputKilowatt), false),
                BuildDelta("Total Heat Out", "kWh", "F1", TotalEnergy(snapsA, s => s.HeatOutputKilowatt), TotalEnergy(snapsB, s => s.HeatOutputKilowatt), true),
                BuildDelta("Avg Flow Temp", "°C", "F1", AvgDec(snapsA, s => s.HeatingFlowTemperatureCelsius), AvgDec(snapsB, s => s.HeatingFlowTemperatureCelsius), false),
            ];

            copChartA = ToElapsed(snapsA, fromA, s => s.CoefficientOfPerformance);
            copChartB = ToElapsed(snapsB, fromB, s => s.CoefficientOfPerformance);
            hasCompareData = true;
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { compareLoading = false; }
    }

    private static List<ScatterPoint> BuildRefLine(List<ScatterPoint> data, double y)
    {
        if (data.Count == 0) return [];
        return [new() { X = data.Min(p => p.X), Y = y }, new() { X = data.Max(p => p.X), Y = y }];
    }

    private static DutyCycleRow BuildDCRow(string period, List<HeatPumpSnapshotDto> items, int from, int to)
    {
        var inPeriod = items.Where(s => s.SnapshotTakenAt.Hour >= from && s.SnapshotTakenAt.Hour < to).ToList();
        return new() { Period = period, Total = inPeriod.Count, Active = inPeriod.Count(s => s.HeatingZoneHeatDemand == true) };
    }

    private static double? AvgDec(List<HeatPumpSnapshotDto> snaps, Func<HeatPumpSnapshotDto, decimal?> sel)
    {
        var vals = snaps.Where(s => sel(s).HasValue).Select(s => (double)sel(s)!.Value).ToList();
        return vals.Count > 0 ? vals.Average() : null;
    }

    private static double? TotalEnergy(List<HeatPumpSnapshotDto> snaps, Func<HeatPumpSnapshotDto, decimal?> powerSel)
    {
        var vals = snaps.Where(s => powerSel(s).HasValue).Select(s => (double)powerSel(s)!.Value).ToList();
        return vals.Count > 0 ? vals.Sum() * 0.25 : null;
    }

    private static List<ElapsedPoint> ToElapsed(List<HeatPumpSnapshotDto> snaps, DateTime start, Func<HeatPumpSnapshotDto, decimal?> sel)
    {
        return snaps.Where(s => sel(s).HasValue).OrderBy(s => s.SnapshotTakenAt)
            .Select(s => new ElapsedPoint { ElapsedHours = Math.Round((s.SnapshotTakenAt - start).TotalHours, 1), Value = (double)sel(s)!.Value }).ToList();
    }

    private static DeltaMetric BuildDelta(string label, string unit, string fmt, double? a, double? b, bool higherBetter, bool neutral = false)
    {
        var delta = a.HasValue && b.HasValue ? b.Value - a.Value : (double?)null;
        var pct = a.HasValue && b.HasValue && a.Value != 0 ? delta / Math.Abs(a.Value) * 100 : null;
        return new()
        {
            Label = label, Unit = unit, ValueA = a?.ToString(fmt) ?? "—", ValueB = b?.ToString(fmt) ?? "—",
            DeltaValue = delta ?? 0, DeltaFormatted = delta?.ToString(fmt) ?? "—", DeltaPercent = pct,
            IsImprovement = delta.HasValue && !neutral && (higherBetter ? delta > 0 : delta < 0),
            IsNeutral = neutral || !delta.HasValue
        };
    }

    private sealed class ScatterPoint { public double X { get; set; } public double Y { get; set; } }
    private sealed class TimePoint { public DateTime Time { get; set; } public double RoomTemp { get; set; } public double Setpoint { get; set; } public double OutdoorTemp { get; set; } }
    private sealed class DutyCycleRow { public string Period { get; set; } = ""; public int Total { get; set; } public int Active { get; set; } public double DutyCycle => Total > 0 ? Active * 100.0 / Total : 0; }
    private sealed class ElapsedPoint { public double ElapsedHours { get; set; } public double Value { get; set; } }
    private sealed class DeltaMetric
    {
        public string Label { get; set; } = ""; public string Unit { get; set; } = ""; public string ValueA { get; set; } = ""; public string ValueB { get; set; } = "";
        public double DeltaValue { get; set; } public string DeltaFormatted { get; set; } = ""; public double? DeltaPercent { get; set; }
        public bool IsImprovement { get; set; } public bool IsNeutral { get; set; }
    }
}
