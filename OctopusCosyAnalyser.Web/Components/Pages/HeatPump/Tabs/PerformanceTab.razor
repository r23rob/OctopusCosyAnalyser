@inject HeatPumpApiClient Api
@rendermode InteractiveServer
@using OctopusCosyAnalyser.Web.Services
@using System.Text.Json

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<RadzenAccordion Multiple="true">
    <!-- Section 1: Snapshot Charts -->
    <Items>
        <RadzenAccordionItem Text="Snapshot Charts" Selected="true" Icon="show_chart">
            <div class="row g-3 mb-3">
                <div class="col-md-2">
                    <label class="form-label">From</label>
                    <input @bind="snapFrom" type="datetime-local" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">To</label>
                    <input @bind="snapTo" type="datetime-local" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary btn-sm w-100" @onclick="LoadSnapshots" disabled="@snapshotsLoading">
                        @(snapshotsLoading ? "Loading..." : "Load Snapshots")
                    </button>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" @onclick="() => SetSnapRange(1)">24h</button>
                        <button class="btn btn-outline-secondary" @onclick="() => SetSnapRange(3)">3d</button>
                        <button class="btn btn-outline-secondary" @onclick="() => SetSnapRange(7)">7d</button>
                        <button class="btn btn-outline-secondary" @onclick="() => SetSnapRange(30)">30d</button>
                    </div>
                </div>
            </div>

            @if (snapshots.Count > 0)
            {
                <div class="d-flex flex-wrap gap-3 mb-2 align-items-center">
                    <label class="d-flex align-items-center gap-1 mb-0"><RadzenCheckBox @bind-Value="showPowerInput" TValue="bool" /> <span style="color:rgb(0,123,255)">Power Input (kW)</span></label>
                    <label class="d-flex align-items-center gap-1 mb-0"><RadzenCheckBox @bind-Value="showHeatOutput" TValue="bool" /> <span style="color:rgb(220,53,69)">Heat Output (kW)</span></label>
                    <label class="d-flex align-items-center gap-1 mb-0"><RadzenCheckBox @bind-Value="showOutdoorTemp" TValue="bool" /> <span style="color:rgb(255,193,7)">Outdoor Temp (\u00b0C)</span></label>
                    <label class="d-flex align-items-center gap-1 mb-0"><RadzenCheckBox @bind-Value="showCop" TValue="bool" /> <span style="color:rgb(40,167,69)">COP</span></label>
                    @if (!string.IsNullOrEmpty(AccountNumber))
                    {
                        <label class="d-flex align-items-center gap-1 mb-0"><RadzenCheckBox @bind-Value="showCost" TValue="bool" Change="OnCostToggled" /> <span style="color:rgb(255,133,27)">Est. Cost (p)</span></label>
                        @if (costLoading)
                        {
                            <span class="text-muted small">Loading rates...</span>
                        }
                    }
                </div>

                @* Main performance chart — all series overlaid on a shared axis *@
                <RadzenChart Style="height: 400px;">
                    <RadzenChartTooltipOptions Visible="true" Shared="true" />
                    @if (showPowerInput)
                    {
                        <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="PowerInputKilowatt"
                                         Title="Power In (kW)" Stroke="rgb(0,123,255)" StrokeWidth="2" />
                    }
                    @if (showHeatOutput)
                    {
                        <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="HeatOutputKilowatt"
                                         Title="Heat Out (kW)" Stroke="rgb(220,53,69)" StrokeWidth="2" />
                    }
                    @if (showOutdoorTemp)
                    {
                        <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="OutdoorTemperatureCelsius"
                                         Title="Outdoor Temp (\u00b0C)" Stroke="rgb(255,193,7)" StrokeWidth="2" />
                    }
                    @if (showCop)
                    {
                        <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="CoefficientOfPerformance"
                                         Title="COP" Stroke="rgb(40,167,69)" StrokeWidth="2" />
                    }
                    @if (showCost && costSeries.Count > 0)
                    {
                        <RadzenLineSeries Data="@costSeries" CategoryProperty="Time" ValueProperty="Value"
                                         Title="Est. Cost (p)" Stroke="rgb(255,133,27)" StrokeWidth="2" />
                    }
                    <RadzenCategoryAxis FormatString="{0:dd MMM HH:mm}" />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                </RadzenChart>

                @* Standalone cost chart (only when cost is the sole focus) *@
                @if (showCost && costSeries.Count > 0 && !showPowerInput && !showHeatOutput && !showOutdoorTemp && !showCop)
                {
                    <RadzenChart Style="height: 250px;" class="mt-3">
                        <RadzenChartTooltipOptions Visible="true" />
                        <RadzenLineSeries Data="@costSeries" CategoryProperty="Time" ValueProperty="Value"
                                         Title="Est. Cost (p)" Stroke="rgb(255,133,27)" StrokeWidth="2" />
                        <RadzenCategoryAxis FormatString="{0:dd MMM HH:mm}" />
                        <RadzenValueAxis Min="0">
                            <RadzenGridLines Visible="true" />
                            <RadzenAxisTitle Text="p" />
                        </RadzenValueAxis>
                        <RadzenLegend Visible="false" />
                    </RadzenChart>
                }

                <div class="row mt-3">
                    <div class="col-md-6">
                        <RadzenChart Style="height: 250px;">
                            <RadzenChartTooltipOptions Visible="true" Shared="true" />
                            <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="WeatherCompensationMinCelsius"
                                             Title="WC Weather Comp Min (°C)" Stroke="rgb(23,162,184)" StrokeWidth="2" LineType="LineType.Dashed" />
                            <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="WeatherCompensationMaxCelsius"
                                             Title="WC Weather Comp Max (°C)" Stroke="rgb(220,53,69)" StrokeWidth="2" LineType="LineType.Dashed" />
                            <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="HeatingFlowTemperatureCelsius"
                                             Title="Fixed Flow Setpoint (°C)" Stroke="rgb(255,133,27)" StrokeWidth="2" />
                            <RadzenCategoryAxis FormatString="{0:dd HH:mm}" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                    <div class="col-md-6">
                        <RadzenChart Style="height: 250px;">
                            <RadzenChartTooltipOptions Visible="true" Shared="true" />
                            <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="PrimaryZoneSetpointCelsius"
                                             Title="Zone Setpoint (°C)" Stroke="rgb(111,66,193)" StrokeWidth="2" />
                            <RadzenLineSeries Data="@snapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="PrimarySensorTemperatureCelsius"
                                             Title="Sensor Temp (°C)" Stroke="rgb(40,167,69)" StrokeWidth="2" />
                            <RadzenCategoryAxis FormatString="{0:dd HH:mm}" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                </div>

                <h5 class="mt-3">Snapshot Statistics</h5>
                <table class="table table-bordered table-sm">
                    <tbody>
                        <tr><td><strong>Data Points</strong></td><td>@snapshots.Count</td></tr>
                        <tr><td><strong>Avg COP</strong></td><td>@AvgOrDash(snapshots.Select(s => s.CoefficientOfPerformance))</td></tr>
                        <tr><td><strong>Avg Power In</strong></td><td>@AvgOrDash(snapshots.Select(s => s.PowerInputKilowatt)) kW</td></tr>
                        <tr><td><strong>Avg Heat Out</strong></td><td>@AvgOrDash(snapshots.Select(s => s.HeatOutputKilowatt)) kW</td></tr>
                        <tr><td><strong>Avg Outdoor Temp</strong></td><td>@AvgOrDash(snapshots.Select(s => s.OutdoorTemperatureCelsius)) °C</td></tr>
                    </tbody>
                </table>
            }
            else if (!snapshotsLoading)
            {
                <p class="text-muted">No snapshot data yet. The background worker captures a snapshot every 15 minutes.</p>
            }
        </RadzenAccordionItem>

        <!-- Section 2: Historic Time Series -->
        <RadzenAccordionItem Text="Historic Time Series" Icon="timeline">
            @if (string.IsNullOrEmpty(euid))
            {
                <div class="alert alert-info">EUID not available. Time series requires device setup.</div>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-body py-2">
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label class="form-label mb-0 fw-bold">Data Source:</label>
                            </div>
                            <div class="col-auto">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn @(useStoredData ? "btn-primary" : "btn-outline-primary")" @onclick="() => useStoredData = true">Stored (DB)</button>
                                    <button class="btn @(!useStoredData ? "btn-primary" : "btn-outline-primary")" @onclick="() => useStoredData = false">Live API</button>
                                </div>
                            </div>
                            <div class="col-auto ms-auto">
                                <button class="btn btn-outline-success btn-sm" @onclick="SyncHistory" disabled="@isSyncing">
                                    @(isSyncing ? "Syncing..." : "Sync History (12 months)")
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(syncMessage))
                        {
                            <div class="alert @(syncMessage.Contains("Synced") ? "alert-success" : "alert-danger") mt-2 mb-0 py-1 small">@syncMessage</div>
                        }
                    </div>
                </div>

                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-2">
                        <label class="form-label">From</label>
                        <input @bind="tsFrom" type="datetime-local" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">To</label>
                        <input @bind="tsTo" type="datetime-local" class="form-control form-control-sm" />
                    </div>
                    @if (!useStoredData)
                    {
                        <div class="col-md-2">
                            <label class="form-label">Grouping</label>
                            <select @bind="grouping" class="form-select form-select-sm">
                                <option value="">Auto</option>
                                <option value="DAY">Day</option>
                                <option value="WEEK">Week</option>
                                <option value="MONTH">Month</option>
                                <option value="YEAR">Year</option>
                            </select>
                        </div>
                    }
                    <div class="col-md-2">
                        <button class="btn btn-primary btn-sm w-100" @onclick="LoadTimeSeries" disabled="@tsLoading">
                            @(tsLoading ? "Loading..." : "Load Data")
                        </button>
                    </div>
                    <div class="col-md-4">
                        <div class="btn-group btn-group-sm w-100">
                            <button class="btn btn-outline-secondary" @onclick="() => SetTsRange(7)">7 Days</button>
                            <button class="btn btn-outline-secondary" @onclick="() => SetTsRange(30)">30 Days</button>
                            <button class="btn btn-outline-secondary" @onclick="() => SetTsRange(90)">90 Days</button>
                            <button class="btn btn-outline-secondary" @onclick="() => SetTsRange(365)">1 Year</button>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(tsStatus))
                {
                    <div class="alert alert-info py-1 small">@tsStatus</div>
                }

                @if (timeSeriesData.Count > 0)
                {
                    <RadzenChart Style="height: 350px;">
                        <RadzenChartTooltipOptions Visible="true" Shared="true" />
                        <RadzenColumnSeries Data="@timeSeriesData" CategoryProperty="EndAt" ValueProperty="EnergyOutputVal"
                                            Title="Energy Output (kWh)" Fill="rgb(220,53,69)" />
                        <RadzenColumnSeries Data="@timeSeriesData" CategoryProperty="EndAt" ValueProperty="EnergyInputVal"
                                            Title="Energy Input (kWh)" Fill="rgb(0,123,255)" />
                        <RadzenLineSeries Data="@timeSeriesData" CategoryProperty="EndAt" ValueProperty="Cop"
                                         Title="COP" Stroke="rgb(40,167,69)" StrokeWidth="2" />
                        <RadzenCategoryAxis FormatString="{0:MMM dd}" />
                        <RadzenValueAxis Min="0"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                        <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                    </RadzenChart>
                }
            }
        </RadzenAccordionItem>

        <!-- Section 3: Sensors & Schedules -->
        <RadzenAccordionItem Text="Sensors & Schedules" Icon="sensors">
            @if (snapshots.Count > 0 && sensorTimeSeries.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-header"><strong>Cosy Pod Temperatures</strong></div>
                    <div class="card-body">
                        <RadzenChart Style="height: 340px;">
                            <RadzenChartTooltipOptions Visible="true" Shared="true" />
                            @foreach (var sensor in sensorTimeSeries.Where(s => s.Value.Count > 0))
                            {
                                <RadzenLineSeries Data="@sensor.Value" CategoryProperty="Time" ValueProperty="Value"
                                                 Title="@sensor.Key" Stroke="@GetSensorColor(sensor.Key)" StrokeWidth="2" />
                            }
                            <RadzenCategoryAxis FormatString="{0:dd MMM HH:mm}" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>Heating Schedule</strong></div>
                    <div class="card-body">
                        <RadzenChart Style="height: 300px;">
                            <RadzenChartTooltipOptions Visible="true" Shared="true" />
                            <RadzenLineSeries Data="@heatingSetpointSeries" CategoryProperty="Time" ValueProperty="Value"
                                             Title="Setpoint (°C)" Stroke="rgb(111,66,193)" StrokeWidth="2" />
                            @if (roomTempSeries.Count > 0)
                            {
                                <RadzenLineSeries Data="@roomTempSeries" CategoryProperty="Time" ValueProperty="Value"
                                                 Title="Room Temp (°C)" Stroke="rgb(40,167,69)" StrokeWidth="2" />
                            }
                            <RadzenColumnSeries Data="@heatingDemandSeries" CategoryProperty="Time" ValueProperty="Value"
                                                Title="Heat Demand Active" Fill="rgba(220,53,69,0.2)" />
                            <RadzenCategoryAxis FormatString="{0:dd MMM HH:mm}" />
                            <RadzenValueAxis><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>Cumulative Energy</strong></div>
                    <div class="card-body">
                        <RadzenChart Style="height: 320px;">
                            <RadzenChartTooltipOptions Visible="true" Shared="true" />
                            <RadzenLineSeries Data="@cumulativeHeatOut" CategoryProperty="Time" ValueProperty="Value"
                                             Title="Heat Output (kWh)" Stroke="rgb(220,53,69)" StrokeWidth="2" />
                            <RadzenLineSeries Data="@cumulativeElecIn" CategoryProperty="Time" ValueProperty="Value"
                                             Title="Electricity In (kWh)" Stroke="rgb(59,130,246)" StrokeWidth="2" />
                            <RadzenCategoryAxis FormatString="{0:dd MMM HH:mm}" />
                            <RadzenValueAxis Min="0"><RadzenGridLines Visible="true" /></RadzenValueAxis>
                            <RadzenLegend Visible="true" Position="LegendPosition.Bottom" />
                        </RadzenChart>
                        <div class="row g-2 mt-3 text-center">
                            <div class="col-6 col-md-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Total Elec In</div>
                                    <div class="fw-bold text-primary">@totalElecIn.ToString("F1") kWh</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Total Heat Out</div>
                                    <div class="fw-bold text-danger">@totalHeatOut.ToString("F1") kWh</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Period COP</div>
                                    <div class="fw-bold text-success">@(totalElecIn > 0 ? (totalHeatOut / totalElecIn).ToString("F2") : "—")</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Multiplier</div>
                                    <div class="fw-bold">@(totalElecIn > 0 ? $"{(totalHeatOut / totalElecIn):F1}x" : "—")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted">Load snapshot data above to see sensor and schedule charts.</p>
            }
        </RadzenAccordionItem>
    </Items>
</RadzenAccordion>

@code {
    [Parameter] public string? DeviceId { get; set; }
    [Parameter] public string? AccountNumber { get; set; }
    [Parameter] public string? Euid { get; set; }

    private string? errorMessage;
    private bool _loaded;

    // Chart toggles
    private bool showPowerInput = true;
    private bool showHeatOutput = true;
    private bool showOutdoorTemp = true;
    private bool showCop = true;
    private bool showCost;
    private bool costLoading;
    private List<SensorPoint> costSeries = [];
    private List<TariffRate> tariffRates = [];

    // Snapshots
    private bool snapshotsLoading;
    private DateTime snapFrom = DateTime.UtcNow.AddDays(-3);
    private DateTime snapTo = DateTime.UtcNow;
    private List<HeatPumpSnapshotDto> snapshots = [];

    // Time series
    private bool tsLoading;
    private bool isSyncing;
    private string? syncMessage;
    private string? tsStatus;
    private bool useStoredData = true;
    private DateTime tsFrom = DateTime.UtcNow.AddDays(-7);
    private DateTime tsTo = DateTime.UtcNow;
    private string grouping = "";
    private string? euid;
    private List<TimeSeriesChartPoint> timeSeriesData = [];

    // Sensor data
    private Dictionary<string, List<SensorPoint>> sensorTimeSeries = new();
    private List<SensorPoint> heatingSetpointSeries = [];
    private List<SensorPoint> heatingDemandSeries = [];
    private List<SensorPoint> roomTempSeries = [];
    private List<SensorPoint> cumulativeElecIn = [];
    private List<SensorPoint> cumulativeHeatOut = [];
    private double totalElecIn, totalHeatOut;

    private readonly string[] _sensorColors = ["rgb(59,130,246)", "rgb(239,68,68)", "rgb(34,197,94)", "rgb(168,85,247)", "rgb(249,115,22)", "rgb(14,165,233)"];
    private int _sensorColorIdx;
    private readonly Dictionary<string, string> _assignedColors = new();

    private string GetSensorColor(string name)
    {
        if (!_assignedColors.TryGetValue(name, out var color))
        {
            color = _sensorColors[_sensorColorIdx % _sensorColors.Length];
            _assignedColors[name] = color;
            _sensorColorIdx++;
        }
        return color;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loaded || string.IsNullOrEmpty(DeviceId)) return;
        _loaded = true;
        euid = Euid;
        await LoadSnapshots();
    }

    private void SetSnapRange(int days) { snapTo = DateTime.UtcNow; snapFrom = DateTime.UtcNow.AddDays(-days); }
    private void SetTsRange(int days) { tsTo = DateTime.UtcNow; tsFrom = DateTime.UtcNow.AddDays(-days); }

    private async Task LoadSnapshots()
    {
        if (string.IsNullOrEmpty(DeviceId)) return;
        snapshotsLoading = true;
        try
        {
            var result = await Api.GetSnapshotsAsync(DeviceId, snapFrom, snapTo);
            snapshots = result?.Snapshots?.OrderBy(s => s.SnapshotTakenAt).ToList() ?? [];
            _sensorColorIdx = 0; _assignedColors.Clear();
            ParseSensorData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { snapshotsLoading = false; }
    }

    private async Task LoadTimeSeries()
    {
        if (useStoredData)
        {
            if (string.IsNullOrEmpty(DeviceId)) return;
            tsLoading = true; tsStatus = "Loading from database..."; timeSeriesData.Clear();
            try
            {
                var result = await Api.GetStoredTimeSeriesAsync(DeviceId, tsFrom, tsTo);
                timeSeriesData = result.Points;
                tsStatus = $"Loaded {timeSeriesData.Count} stored data points.";
            }
            catch (Exception ex) { tsStatus = $"Error: {ex.Message}"; }
            finally { tsLoading = false; }
        }
        else
        {
            if (string.IsNullOrEmpty(AccountNumber) || string.IsNullOrEmpty(euid)) { tsStatus = "Account or EUID not set."; return; }
            tsLoading = true; tsStatus = "Loading from Octopus API..."; timeSeriesData.Clear();
            try
            {
                var result = await Api.GetTimeSeriesAsync(AccountNumber, euid, tsFrom, tsTo,
                    string.IsNullOrEmpty(grouping) ? null : grouping);
                timeSeriesData = result.Points;
                tsStatus = $"Loaded {timeSeriesData.Count} data points.";
            }
            catch (Exception ex) { tsStatus = $"Error: {ex.Message}"; }
            finally { tsLoading = false; }
        }
    }

    private async Task SyncHistory()
    {
        if (string.IsNullOrEmpty(DeviceId)) return;
        isSyncing = true; syncMessage = "Syncing..."; StateHasChanged();
        try { var r = await Api.SyncTimeSeriesAsync(DeviceId); syncMessage = $"Synced {r.Synced} records."; }
        catch (Exception ex) { syncMessage = $"Error: {ex.Message}"; }
        finally { isSyncing = false; }
    }

    private void ParseSensorData()
    {
        sensorTimeSeries = new();
        heatingSetpointSeries = []; heatingDemandSeries = []; roomTempSeries = [];
        cumulativeElecIn = []; cumulativeHeatOut = [];
        double cumIn = 0, cumOut = 0;

        foreach (var snap in snapshots)
        {
            // Parse JSON sensors
            if (!string.IsNullOrEmpty(snap.SensorReadingsJson))
            {
                try
                {
                    using var doc = JsonDocument.Parse(snap.SensorReadingsJson);
                    foreach (var sensor in doc.RootElement.EnumerateArray())
                    {
                        var code = sensor.TryGetProperty("code", out var c) ? c.GetString() ?? "" : "";
                        if (!sensor.TryGetProperty("tempC", out var tempEl) || !tempEl.TryGetDouble(out var temp)) continue;
                        var hasHumidity = sensor.TryGetProperty("humidity", out var humEl) && humEl.TryGetDouble(out var hum) && hum > 0;
                        if (hasHumidity)
                        {
                            if (!sensorTimeSeries.ContainsKey(code)) sensorTimeSeries[code] = [];
                            sensorTimeSeries[code].Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = temp });
                        }
                    }
                }
                catch { }
            }

            // Schedule data
            if (snap.HeatingZoneSetpointCelsius.HasValue)
                heatingSetpointSeries.Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = (double)snap.HeatingZoneSetpointCelsius.Value });
            heatingDemandSeries.Add(new SensorPoint
            {
                Time = snap.SnapshotTakenAt,
                Value = snap.HeatingZoneHeatDemand == true ? (snap.HeatingZoneSetpointCelsius.HasValue ? (double)snap.HeatingZoneSetpointCelsius.Value : 20) : 0
            });
            if (snap.RoomTemperatureCelsius.HasValue)
                roomTempSeries.Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = (double)snap.RoomTemperatureCelsius.Value });

            // Cumulative energy
            if (snap.PowerInputKilowatt.HasValue) { cumIn += (double)snap.PowerInputKilowatt.Value * 0.25; cumulativeElecIn.Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = Math.Round(cumIn, 2) }); }
            if (snap.HeatOutputKilowatt.HasValue) { cumOut += (double)snap.HeatOutputKilowatt.Value * 0.25; cumulativeHeatOut.Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = Math.Round(cumOut, 2) }); }
        }
        totalElecIn = cumIn; totalHeatOut = cumOut;
    }

    private static string AvgOrDash(IEnumerable<decimal?> values)
    {
        var valid = values.Where(v => v.HasValue).Select(v => v!.Value).ToList();
        return valid.Count > 0 ? valid.Average().ToString("F2") : "—";
    }

    private async Task OnCostToggled(bool value)
    {
        showCost = value;
        if (showCost && tariffRates.Count == 0 && !string.IsNullOrEmpty(AccountNumber))
        {
            await LoadTariffRates();
        }
        if (showCost)
        {
            ComputeCostSeries();
        }
    }

    private async Task LoadTariffRates()
    {
        costLoading = true;
        try
        {
            var raw = await Api.GetApplicableRatesRawAsync(AccountNumber!, snapFrom, snapTo);
            tariffRates.Clear();
            var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("data", out var dataEl) && dataEl.TryGetProperty("applicableRates", out var ratesEl)
                && ratesEl.ValueKind == System.Text.Json.JsonValueKind.Object && ratesEl.TryGetProperty("edges", out var edgesEl))
            {
                foreach (var edge in edgesEl.EnumerateArray())
                {
                    if (!edge.TryGetProperty("node", out var node)) continue;
                    var validFrom = node.TryGetProperty("validFrom", out var vf) ? vf.GetString() : null;
                    var validTo = node.TryGetProperty("validTo", out var vt) ? vt.GetString() : null;
                    var val = GetDoubleFromJson(node, "value");
                    if (validFrom != null && DateTimeOffset.TryParse(validFrom, out var fromDto))
                    {
                        tariffRates.Add(new TariffRate
                        {
                            ValidFrom = fromDto.UtcDateTime,
                            ValidTo = validTo != null && DateTimeOffset.TryParse(validTo, out var toDto) ? toDto.UtcDateTime : DateTime.MaxValue,
                            PencePerKwh = val
                        });
                    }
                }
                tariffRates = tariffRates.OrderBy(r => r.ValidFrom).ToList();
            }
        }
        catch { }
        finally { costLoading = false; }
    }

    private void ComputeCostSeries()
    {
        costSeries.Clear();
        if (tariffRates.Count == 0) return;
        foreach (var snap in snapshots)
        {
            if (!snap.PowerInputKilowatt.HasValue) continue;
            var rate = tariffRates.LastOrDefault(r => r.ValidFrom <= snap.SnapshotTakenAt);
            if (rate == null) continue;
            var costPence = (double)snap.PowerInputKilowatt.Value * 0.25 * rate.PencePerKwh;
            costSeries.Add(new SensorPoint { Time = snap.SnapshotTakenAt, Value = Math.Round(costPence, 2) });
        }
    }

    private static double GetDoubleFromJson(System.Text.Json.JsonElement el, string prop)
    {
        if (!el.TryGetProperty(prop, out var val)) return 0;
        if (val.ValueKind == System.Text.Json.JsonValueKind.Number && val.TryGetDouble(out var d)) return d;
        if (val.ValueKind == System.Text.Json.JsonValueKind.String && double.TryParse(val.GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var p)) return p;
        return 0;
    }

    private sealed class SensorPoint { public DateTime Time { get; set; } public double Value { get; set; } }
    private sealed class TariffRate { public DateTime ValidFrom { get; set; } public DateTime ValidTo { get; set; } public double PencePerKwh { get; set; } }
}
