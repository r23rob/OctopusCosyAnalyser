@page "/"
@page "/heatpump"
@inject HeatPumpApiClient Api
@implements IDisposable
@rendermode InteractiveServer
@using OctopusCosyAnalyser.Web.Components.Pages.HeatPump.Tabs
@using OctopusCosyAnalyser.Shared.Models

<PageTitle>Heat Pump – Dashboard</PageTitle>

@if (!isSetup)
{
    <div class="setup-card">
        <h3>Heat Pump Dashboard</h3>
        <p>Save your account number and API key in <a href="/settings">Account Settings</a>, then set up the device.</p>
        <button @onclick="SetupDevice" class="btn btn-primary" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <span>Setting up...</span>
            }
            else
            {
                <span>Setup Device</span>
            }
        </button>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <!-- ═══ HERO GAUGES ═══ -->
    <div class="gauge-section">
        <div class="gauge-card" role="figure" aria-label="Live COP: @CopDisplay">
            <div class="gauge-card-label" aria-hidden="true">Live COP</div>
            <RadzenRadialGauge Style="width: 180px; height: 140px;" aria-hidden="true">
                <RadzenRadialGaugeScale StartAngle="-150" EndAngle="150"
                                        Min="0" Max="6" Step="2" MinorStep="1"
                                        TickPosition="GaugeTickPosition.Outside"
                                        Radius="0.8"
                                        Stroke="transparent">
                    <RadzenRadialGaugeScaleRange From="0" To="2.5" Fill="#ef4444" Height="12" />
                    <RadzenRadialGaugeScaleRange From="2.5" To="3.5" Fill="#f59e0b" Height="12" />
                    <RadzenRadialGaugeScaleRange From="3.5" To="6" Fill="#22c55e" Height="12" />
                    <RadzenRadialGaugeScalePointer Value="@(_parsedCop ?? 0)" ShowValue="false"
                                                   Length="0.6" Fill="rgba(255,255,255,0.85)" />
                </RadzenRadialGaugeScale>
            </RadzenRadialGauge>
            <div class="gauge-card-value @CopColorClass">@CopDisplay</div>
        </div>

        <div class="gauge-card" role="figure" aria-label="Power Input: @PowerInputDisplay kW">
            <div class="gauge-card-label" aria-hidden="true">Power Input</div>
            <RadzenRadialGauge Style="width: 180px; height: 140px;" aria-hidden="true">
                <RadzenRadialGaugeScale StartAngle="-150" EndAngle="150"
                                        Min="0" Max="@PowerGaugeMax" Step="@(PowerGaugeMax / 4)" MinorStep="0"
                                        TickPosition="GaugeTickPosition.Outside"
                                        Radius="0.8"
                                        Stroke="transparent">
                    <RadzenRadialGaugeScaleRange From="0" To="@PowerGaugeMax" Fill="#3b82f6" Height="12" />
                    <RadzenRadialGaugeScalePointer Value="@(_parsedPowerInput ?? 0)" ShowValue="false"
                                                   Length="0.6" Fill="rgba(255,255,255,0.85)" />
                </RadzenRadialGaugeScale>
            </RadzenRadialGauge>
            <div class="gauge-card-value" style="color: var(--color-primary);">@PowerInputDisplay</div>
            <div class="gauge-card-unit">kW</div>
        </div>

        <div class="gauge-card" role="figure" aria-label="Heat Output: @HeatOutputDisplay kW">
            <div class="gauge-card-label" aria-hidden="true">Heat Output</div>
            <RadzenRadialGauge Style="width: 180px; height: 140px;" aria-hidden="true">
                <RadzenRadialGaugeScale StartAngle="-150" EndAngle="150"
                                        Min="0" Max="@HeatGaugeMax" Step="@(HeatGaugeMax / 4)" MinorStep="0"
                                        TickPosition="GaugeTickPosition.Outside"
                                        Radius="0.8"
                                        Stroke="transparent">
                    <RadzenRadialGaugeScaleRange From="0" To="@HeatGaugeMax" Fill="#22c55e" Height="12" />
                    <RadzenRadialGaugeScalePointer Value="@(_parsedHeatOutput ?? 0)" ShowValue="false"
                                                   Length="0.6" Fill="rgba(255,255,255,0.85)" />
                </RadzenRadialGaugeScale>
            </RadzenRadialGauge>
            <div class="gauge-card-value" style="color: var(--color-success);">@HeatOutputDisplay</div>
            <div class="gauge-card-unit">kW</div>
        </div>
    </div>

    <!-- ═══ STATUS PILLS ═══ -->
    <div class="status-pills" role="status" aria-live="polite" aria-label="System status">
        @{ var controllerState = summary?.ControllerConfiguration?.Controller?.State; }
        @if (controllerState?.Count > 0)
        {
            var isHeating = controllerState.Any(s => s.Contains("HEAT", StringComparison.OrdinalIgnoreCase));
            <span class="status-pill" aria-label="@(isHeating ? "Controller: heating" : "Controller: idle")">
                <span class="status-dot @(isHeating ? "status-dot-danger status-dot-pulse" : "status-dot-info")" aria-hidden="true"></span>
                @(isHeating ? "HEATING" : "IDLE")
            </span>
        }

        @{
            var wcStatus = summary?.ControllerConfiguration?.HeatPump?.WeatherCompensation?.Enabled;
            var (wcDotClass, wcText) = wcStatus switch
            {
                true  => ("status-dot-success", "Weather Comp"),
                false => ("status-dot-info", "Fixed Flow"),
                _     => ("status-dot-muted", "Mode Unknown")
            };
        }
        <span class="status-pill" aria-label="Flow mode: @wcText">
            <span class="status-dot @wcDotClass" aria-hidden="true"></span>
            @wcText
        </span>

        @if (summary?.ControllerStatus?.Zones != null)
        {
            @foreach (var zone in summary.ControllerStatus.Zones.Where(z => z.Telemetry?.HeatDemand == true))
            {
                <span class="status-pill" aria-label="@(zone.Zone ?? "Zone") has heat demand">
                    <span class="status-dot status-dot-warning status-dot-pulse" aria-hidden="true"></span>
                    @(zone.Zone ?? "Zone") demand
                </span>
            }
        }

        @if (latestSnapshot != null)
        {
            <span class="status-pill" aria-label="Snapshot worker: @SnapshotHealthText">
                <span class="status-dot @SnapshotHealthDot" aria-hidden="true"></span>
                Worker: @SnapshotHealthText
            </span>
        }

        <span class="status-pill" style="color: var(--text-muted); font-size: var(--font-size-sm);">
            @(summary?.LivePerformance?.ReadAt ?? "—")
            <button class="btn btn-link btn-sm p-0 ms-1" @onclick="RefreshDashboard" disabled="@isLoading"
                    aria-label="Refresh dashboard"
                    style="font-size: var(--font-size-sm); text-decoration: none; color: var(--color-primary);">
                @(isLoading ? "..." : "↻")
            </button>
        </span>
    </div>

    <!-- ═══ PERIOD SELECTOR ═══ -->
    <PeriodSelector SelectedDays="@selectedPeriodDays"
                    SelectedDaysChanged="SetPeriod"
                    IsLoading="@periodLoading" />

    <!-- ═══ METRICS STRIP ═══ -->
    <div class="metrics-strip">
        <div class="metric-item">
            <div class="metric-label">Avg COP</div>
            <div class="metric-value @PeriodCopColorClass">@FmtDec(periodSummary?.AvgCop)</div>
            <div class="metric-range">@FmtDec(periodSummary?.MinCop) – @FmtDec(periodSummary?.MaxCop)</div>
        </div>
        <div class="metric-item">
            <div class="metric-label">Energy In</div>
            <div class="metric-value" style="color: var(--color-primary);">@FmtKwh(periodSummary?.TotalInputKwh)</div>
            <div class="metric-range">kWh</div>
        </div>
        <div class="metric-item">
            <div class="metric-label">Heat Out</div>
            <div class="metric-value" style="color: var(--color-success);">@FmtKwh(periodSummary?.TotalOutputKwh)</div>
            <div class="metric-range">kWh</div>
        </div>
        <div class="metric-item">
            <div class="metric-label">Outdoor</div>
            <div class="metric-value" style="color: var(--color-warning);">@FmtTemp(periodSummary?.AvgOutdoorTemp)</div>
            <div class="metric-range">@FmtTemp(periodSummary?.MinOutdoorTemp) – @FmtTemp(periodSummary?.MaxOutdoorTemp)</div>
        </div>
        <div class="metric-item">
            <div class="metric-label">Room</div>
            <div class="metric-value">@FmtTemp(periodSummary?.AvgRoomTemp)</div>
            <div class="metric-range">@FmtTemp(periodSummary?.MinRoomTemp) – @FmtTemp(periodSummary?.MaxRoomTemp)</div>
        </div>
        @if (periodSummary?.SnapshotCount > 0)
        {
            <div class="metric-item">
                <div class="metric-label">Heating</div>
                <div class="metric-value">@periodSummary.HeatingDutyCyclePercent.ToString("F0")%</div>
                <div class="metric-range">duty cycle</div>
            </div>
        }
    </div>

    <!-- ═══ UNIFIED CHART ═══ -->
    @if (trendSnapshots.Count > 0)
    {
        <div class="chart-section">
            <div class="chart-header">
                <span class="chart-title">@PeriodLabel — @trendSnapshots.Count points</span>
                <div class="chart-toggles">
                    <SeriesToggle Color="var(--chart-4)" Label="COP"       @bind-Active="showCop" />
                    <SeriesToggle Color="var(--chart-1)" Label="Power In"  @bind-Active="showPowerIn" />
                    <SeriesToggle Color="var(--chart-3)" Label="Heat Out"  @bind-Active="showHeatOut" />
                    <SeriesToggle Color="var(--chart-6)" Label="Outdoor"   @bind-Active="showOutdoor" />
                </div>
            </div>
            <RadzenChart Style="height: 350px;">
                @if (showCop)
                {
                    <RadzenLineSeries Data="@trendSnapshots" CategoryProperty="SnapshotTakenAt"
                                     ValueProperty="CoefficientOfPerformance"
                                     Stroke="#22c55e" StrokeWidth="2" Title="COP" />
                    <RadzenLineSeries Data="@cop3RefLine" CategoryProperty="Time" ValueProperty="Value"
                                     Stroke="rgba(239,68,68,0.3)" StrokeWidth="1" LineType="LineType.Dashed" Title="COP 3.0" />
                }
                @if (showPowerIn)
                {
                    <RadzenLineSeries Data="@trendSnapshots" CategoryProperty="SnapshotTakenAt"
                                     ValueProperty="PowerInputKilowatt"
                                     Stroke="#3b82f6" StrokeWidth="2" Title="Power In (kW)" />
                }
                @if (showHeatOut)
                {
                    <RadzenLineSeries Data="@trendSnapshots" CategoryProperty="SnapshotTakenAt"
                                     ValueProperty="HeatOutputKilowatt"
                                     Stroke="#f59e0b" StrokeWidth="2" Title="Heat Out (kW)" />
                }
                @if (showOutdoor)
                {
                    <RadzenLineSeries Data="@trendSnapshots" CategoryProperty="SnapshotTakenAt"
                                     ValueProperty="OutdoorTemperature"
                                     Stroke="#06b6d4" StrokeWidth="2" Title="Outdoor (°C)" />
                }
                <RadzenCategoryAxis FormatString="@TrendAxisFormat" Visible="true" />
                <RadzenValueAxis Min="0" Visible="true">
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        </div>
    }
    else if (!periodLoading && periodSummary != null)
    {
        <div class="alert alert-info" style="text-align: center;">No snapshot data available for this period.</div>
    }

    <!-- ═══ AI SUMMARY (Collapsible) ═══ -->
    <div class="ai-panel">
        <div class="ai-panel-header"
             @onclick="() => aiExpanded = !aiExpanded"
             role="button"
             tabindex="0"
             aria-expanded="@aiExpanded.ToString().ToLower()"
             aria-controls="ai-panel-body">
            <span class="ai-panel-title">
                AI Performance Summary
            </span>
            <div class="ai-panel-meta">
                @if (aiSummary is not null && aiSummary.GeneratedAt != default)
                {
                    <span style="font-size: var(--font-size-sm); color: var(--text-muted);">@aiSummary.GeneratedAt.ToString("dd MMM HH:mm")</span>
                }
                <button class="btn btn-outline-secondary btn-sm" style="font-size: var(--font-size-sm); padding: 0.15rem 0.5rem;"
                        @onclick="RefreshAiSummary" @onclick:stopPropagation="true" disabled="@aiLoading"
                        aria-label="Refresh AI summary">
                    @(aiLoading ? "..." : "Refresh")
                </button>
                <span class="ai-panel-chevron @(aiExpanded ? "ai-panel-chevron-open" : "")" aria-hidden="true">▼</span>
            </div>
        </div>

        @if (aiExpanded)
        {
            <div class="ai-panel-body" id="ai-panel-body">
                @if (aiLoading && aiSummary == null)
                {
                    <div class="d-flex align-items-center p-2">
                        <div class="spinner-border spinner-border-sm me-2" role="status" style="width: 1rem; height: 1rem;"></div>
                        <span style="color: var(--text-muted); font-size: 0.85rem;">Generating AI summary...</span>
                    </div>
                }
                else if (aiSummary != null && !string.IsNullOrEmpty(aiSummary.WeekSummary))
                {
                    @if (!string.IsNullOrEmpty(aiSummary.WeekSummary))
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Last 7 Days</div>
                            <div class="ai-section-text">@aiSummary.WeekSummary</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(aiSummary.MonthSummary))
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Last 30 Days</div>
                            <div class="ai-section-text">@aiSummary.MonthSummary</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(aiSummary.YearSummary))
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Last 12 Months</div>
                            <div class="ai-section-text">@aiSummary.YearSummary</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(aiSummary.Suggestions))
                    {
                        <div class="ai-section ai-suggestions">
                            <div class="ai-section-label">Suggestions</div>
                            <div class="ai-section-text">@aiSummary.Suggestions</div>
                        </div>
                    }
                }
            </div>
        }
    </div>

    <!-- ═══ TABBED DETAIL AREA ═══ -->
    <RadzenTabs @bind-SelectedIndex="selectedTab" Style="margin-top: 0.5rem;">
        <Tabs>
            <RadzenTabsItem Text="Performance & History" Icon="show_chart">
                @if (selectedTab == 0)
                {
                    <PerformanceTab DeviceId="@deviceId" AccountNumber="@accountNumber" Euid="@euid" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Comfort & System" Icon="home">
                @if (selectedTab == 1)
                {
                    <ComfortTab Summary="@summary" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Analysis" Icon="insights">
                @if (selectedTab == 2)
                {
                    <AnalysisTab DeviceId="@deviceId" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Costs" Icon="payments">
                @if (selectedTab == 3)
                {
                    <CostsTab AccountNumber="@accountNumber" DeviceId="@deviceId" />
                }
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@code {
    private string accountNumber = "";
    private string? deviceId;
    private string? euid;
    private bool isSetup;
    private bool isLoading;
    private string? errorMessage;
    private HeatPumpSummaryDto? summary;
    private LatestSnapshotDto? latestSnapshot;
    private int selectedTab;

    // AI Summary
    private AiSummaryDto? aiSummary;
    private bool aiLoading;
    private bool aiExpanded;

    // Period summary
    private PeriodSummaryDto? periodSummary;
    private bool periodLoading;
    private int selectedPeriodDays = 7;
    private int _periodLoadVersion;

    // Trend chart
    private List<HeatPumpSnapshotDto> trendSnapshots = [];
    private List<RefPoint> cop3RefLine = [];

    // Chart toggles
    private bool showCop = true;
    private bool showPowerIn;
    private bool showHeatOut;
    private bool showOutdoor;

    // Auto-refresh timer
    private System.Threading.Timer? _refreshTimer;

    // Parsed live values
    private double? _parsedCop;
    private double? _parsedPowerInput;
    private double? _parsedHeatOutput;

    private string CopDisplay => _parsedCop.HasValue ? _parsedCop.Value.ToString("F2") : "—";
    private string PowerInputDisplay => _parsedPowerInput.HasValue ? _parsedPowerInput.Value.ToString("F2") : "—";
    private string HeatOutputDisplay => _parsedHeatOutput.HasValue ? _parsedHeatOutput.Value.ToString("F2") : "—";

    private double PowerGaugeMax => Math.Max(8, Math.Ceiling((_parsedPowerInput ?? 4) * 1.5));
    private double HeatGaugeMax => Math.Max(16, Math.Ceiling((_parsedHeatOutput ?? 8) * 1.5));

    private string CopColorClass => _parsedCop switch
    {
        >= 3.5 => "cop-green",
        >= 2.5 => "cop-amber",
        _ when _parsedCop.HasValue => "cop-red",
        _ => ""
    };

    private string PeriodCopColorClass => periodSummary?.AvgCop switch
    {
        >= 3.5 => "cop-green",
        >= 2.5 => "cop-amber",
        _ when periodSummary?.AvgCop.HasValue == true => "cop-red",
        _ => ""
    };

    private string PeriodLabel => selectedPeriodDays switch
    {
        1 => "Last 24 Hours",
        7 => "Last 7 Days",
        30 => "Last 30 Days",
        365 => "Last 12 Months",
        _ => $"Last {selectedPeriodDays} Days"
    };

    private string TrendAxisFormat => selectedPeriodDays <= 1 ? "{0:HH:mm}" : selectedPeriodDays <= 7 ? "{0:ddd HH:mm}" : "{0:MMM dd}";

    private string SnapshotHealthDot
    {
        get
        {
            if (latestSnapshot?.HasData != true) return "status-dot-warning";
            var mins = latestSnapshot.MinutesAgo ?? double.MaxValue;
            if (mins < 20) return "status-dot-success";
            if (mins < 60) return "status-dot-warning";
            return "status-dot-danger";
        }
    }

    private string SnapshotHealthText
    {
        get
        {
            if (latestSnapshot?.HasData != true) return "No snapshots";
            var mins = (int)(latestSnapshot.MinutesAgo ?? 0);
            if (mins < 20) return "Healthy";
            if (mins < 60) return $"Delayed ({mins}m)";
            return $"Stale ({mins}m)";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAndDevice();
        if (isSetup)
        {
            await RefreshDashboard();
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    await RefreshLiveData();
                    await InvokeAsync(StateHasChanged);
                }
                catch { }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
    }

    private async Task LoadSettingsAndDevice()
    {
        try
        {
            var settings = await Api.GetSettingsAsync();
            var current = settings.FirstOrDefault();
            if (!string.IsNullOrWhiteSpace(current?.AccountNumber))
                accountNumber = current.AccountNumber;

            var devices = await Api.GetDevicesAsync();
            if (devices.Length > 0)
            {
                accountNumber = devices[0].AccountNumber;
                deviceId = devices[0].DeviceId;
                euid = devices[0].Euid;
                isSetup = true;
            }
        }
        catch (Exception ex) { errorMessage = $"Failed to load: {ex.Message}"; }
    }

    private async Task SetupDevice()
    {
        if (string.IsNullOrWhiteSpace(accountNumber))
        { errorMessage = "Save account settings first."; return; }
        isLoading = true; errorMessage = null;
        try
        {
            var result = await Api.SetupDeviceAsync(accountNumber);
            deviceId = result?.DeviceId; euid = result?.Euid; isSetup = true;
            await RefreshDashboard();
        }
        catch (Exception ex) { errorMessage = $"Setup failed: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task RefreshDashboard()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        isLoading = true;
        try
        {
            var summaryTask = Api.GetSummaryAsync(deviceId);
            var latestTask = Api.GetLatestSnapshotAsync(deviceId);
            await Task.WhenAll(summaryTask, latestTask);

            summary = summaryTask.Result;
            latestSnapshot = latestTask.Result;
            ParseLiveValues();

            _ = LoadPeriodDataAsync();
            _ = LoadAiSummaryAsync();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    private async Task SetPeriod(int days)
    {
        selectedPeriodDays = days;
        await LoadPeriodDataAsync();
    }

    private async Task LoadPeriodDataAsync()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        var thisVersion = Interlocked.Increment(ref _periodLoadVersion);
        periodLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var from = DateTime.UtcNow.AddDays(-selectedPeriodDays);
            var to = DateTime.UtcNow;

            var periodTask = Api.GetPeriodSummaryAsync(deviceId, from, to);
            var snapshotsTask = Api.GetSnapshotsAsync(deviceId, from, to);
            await Task.WhenAll(periodTask, snapshotsTask);

            if (thisVersion != _periodLoadVersion) return;

            periodSummary = periodTask.Result;
            var allSnapshots = snapshotsTask.Result?.Snapshots?.OrderBy(s => s.SnapshotTakenAt).ToList() ?? [];

            trendSnapshots = selectedPeriodDays > 7 ? DownsampleSnapshots(allSnapshots, maxPoints: 500) : allSnapshots;
            BuildCop3RefLine();
        }
        catch (Exception ex)
        {
            if (thisVersion == _periodLoadVersion)
                errorMessage = $"Period data failed: {ex.Message}";
        }
        finally
        {
            if (thisVersion == _periodLoadVersion)
            {
                periodLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static List<HeatPumpSnapshotDto> DownsampleSnapshots(List<HeatPumpSnapshotDto> snapshots, int maxPoints)
    {
        if (snapshots.Count <= maxPoints) return snapshots;
        var step = (double)snapshots.Count / maxPoints;
        var result = new List<HeatPumpSnapshotDto>(maxPoints);
        for (var i = 0; i < maxPoints; i++)
            result.Add(snapshots[(int)(i * step)]);
        return result;
    }

    private async Task RefreshLiveData()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        try
        {
            summary = await Api.GetSummaryAsync(deviceId);
            latestSnapshot = await Api.GetLatestSnapshotAsync(deviceId);
            ParseLiveValues();
        }
        catch { }
    }

    private void ParseLiveValues()
    {
        _parsedCop = TryParseValue(summary?.LivePerformance?.CoefficientOfPerformance);
        _parsedPowerInput = TryParseValue(summary?.LivePerformance?.PowerInput?.Value);
        _parsedHeatOutput = TryParseValue(summary?.LivePerformance?.HeatOutput?.Value);
    }

    private static double? TryParseValue(string? value)
    {
        if (value != null && double.TryParse(value, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var result))
            return result;
        return null;
    }

    private void BuildCop3RefLine()
    {
        if (trendSnapshots.Count < 2) { cop3RefLine = []; return; }
        cop3RefLine =
        [
            new RefPoint { Time = trendSnapshots.First().SnapshotTakenAt, Value = 3.0m },
            new RefPoint { Time = trendSnapshots.Last().SnapshotTakenAt, Value = 3.0m }
        ];
    }

    private async Task LoadAiSummaryAsync()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        aiLoading = true;
        await InvokeAsync(StateHasChanged);
        try { aiSummary = await Api.GetAiSummaryAsync(deviceId); }
        catch { }
        finally { aiLoading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task RefreshAiSummary()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        aiLoading = true;
        try { aiSummary = await Api.RefreshAiSummaryAsync(deviceId); }
        catch (Exception ex) { errorMessage = $"AI refresh failed: {ex.Message}"; }
        finally { aiLoading = false; }
    }

    private static string FmtDec(double? v) => v.HasValue ? v.Value.ToString("F2") : "—";
    private static string FmtTemp(double? v) => v.HasValue ? $"{v.Value:F1}°" : "—";
    private static string FmtPct(double? v) => v.HasValue ? $"{v.Value:F1}%" : "—";
    private static string FmtKwh(double? v) => v.HasValue ? $"{v.Value:F1}" : "—";

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private sealed class RefPoint
    {
        public DateTime Time { get; set; }
        public decimal Value { get; set; }
    }
}
