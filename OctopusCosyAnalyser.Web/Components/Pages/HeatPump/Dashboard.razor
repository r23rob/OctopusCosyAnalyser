@page "/heatpump"
@inject HeatPumpApiClient Api
@implements IDisposable
@rendermode InteractiveServer
@using OctopusCosyAnalyser.Web.Components.Pages.HeatPump.Tabs
@using OctopusCosyAnalyser.Shared.Models

<PageTitle>Heat Pump – Dashboard</PageTitle>

@if (!isSetup)
{
    <h1>Heat Pump Dashboard</h1>
    <div class="card mt-4">
        <div class="card-body">
            <h3>Initial Setup</h3>
            <p>Save your account number and API key in <a href="/settings">Account Settings</a>, then set up the device.</p>
            <button @onclick="SetupDevice" class="btn btn-primary" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Setting up...</span>
                }
                else
                {
                    <span>Setup Device</span>
                }
            </button>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <!-- ═══ STATUS BAR (compact live status) ═══ -->
    <div class="status-bar">
        @{ var controllerState = summary?.ControllerConfiguration?.Controller?.State; }
        @if (controllerState?.Count > 0)
        {
            var isHeating = controllerState.Any(s => s.Contains("HEAT", StringComparison.OrdinalIgnoreCase));
            <span class="badge @(isHeating ? "bg-danger" : "bg-info")">@(isHeating ? "HEATING" : "IDLE")</span>
        }

        @if (_parsedCop.HasValue)
        {
            <span class="badge @(CopColorClass == "cop-green" ? "bg-success" : CopColorClass == "cop-amber" ? "bg-warning text-dark" : "bg-danger")">
                Live COP: @CopDisplay
            </span>
        }

        @{ var wcEnabled = summary?.ControllerConfiguration?.HeatPump?.WeatherCompensation?.Enabled == true; }
        <span class="badge @(wcEnabled ? "bg-success" : "bg-secondary")">WC: @(wcEnabled ? "ON" : "OFF")</span>

        @if (summary?.ControllerStatus?.Zones != null)
        {
            @foreach (var zone in summary.ControllerStatus.Zones.Where(z => z.Telemetry?.HeatDemand == true))
            {
                <span class="badge bg-warning text-dark">@(zone.Zone ?? "Zone") demand</span>
            }
        }

        @if (latestSnapshot != null)
        {
            <span class="badge @SnapshotHealthBadge">
                Worker: @SnapshotHealthText
            </span>
        }

        <span class="badge bg-light text-muted border ms-auto">
            @(summary?.LivePerformance?.ReadAt ?? "—")
            <button class="btn btn-link btn-sm p-0 ms-1" @onclick="RefreshDashboard" disabled="@isLoading" style="font-size: 0.75rem; text-decoration: none;">
                @(isLoading ? "..." : "Refresh")
            </button>
        </span>
    </div>

    <!-- ═══ PERIOD SELECTOR ═══ -->
    <div class="period-selector">
        <div class="btn-group" role="group">
            <button class="btn @(selectedPeriodDays == 1 ? "btn-primary" : "btn-outline-primary") btn-sm" @onclick="() => SetPeriod(1)">1 Day</button>
            <button class="btn @(selectedPeriodDays == 7 ? "btn-primary" : "btn-outline-primary") btn-sm" @onclick="() => SetPeriod(7)">1 Week</button>
            <button class="btn @(selectedPeriodDays == 30 ? "btn-primary" : "btn-outline-primary") btn-sm" @onclick="() => SetPeriod(30)">1 Month</button>
            <button class="btn @(selectedPeriodDays == 365 ? "btn-primary" : "btn-outline-primary") btn-sm" @onclick="() => SetPeriod(365)">1 Year</button>
        </div>
        @if (periodLoading)
        {
            <span class="spinner-border spinner-border-sm ms-2" role="status"></span>
        }
        @if (periodSummary?.SnapshotCount > 0)
        {
            <span class="small text-muted ms-2">@periodSummary.SnapshotCount snapshots</span>
        }
    </div>

    <!-- ═══ KEY INDICATORS ═══ -->
    <div class="row g-2 mb-2">
        <div class="col-6 col-md-3">
            <div class="summary-card">
                <div class="summary-label">Avg COP</div>
                <div class="summary-value @PeriodCopColorClass">@FmtDec(periodSummary?.AvgCop)</div>
                <div class="summary-range">@FmtDec(periodSummary?.MinCop) – @FmtDec(periodSummary?.MaxCop)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card">
                <div class="summary-label">Input Energy</div>
                <div class="summary-value text-primary">@FmtKwh(periodSummary?.TotalInputKwh)</div>
                <div class="summary-range">total kWh</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card">
                <div class="summary-label">Heat Output</div>
                <div class="summary-value text-danger">@FmtKwh(periodSummary?.TotalOutputKwh)</div>
                <div class="summary-range">total kWh</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card">
                <div class="summary-label">Outdoor Temp</div>
                <div class="summary-value text-warning">@FmtTemp(periodSummary?.AvgOutdoorTemp)</div>
                <div class="summary-range">@FmtTemp(periodSummary?.MinOutdoorTemp) – @FmtTemp(periodSummary?.MaxOutdoorTemp)</div>
            </div>
        </div>
    </div>

    <!-- ═══ SENSOR SUMMARIES ═══ -->
    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="summary-card summary-card-sensor">
                <div class="summary-label">Room Temp</div>
                <div class="summary-value">@FmtTemp(periodSummary?.AvgRoomTemp)</div>
                <div class="summary-range">@FmtTemp(periodSummary?.MinRoomTemp) – @FmtTemp(periodSummary?.MaxRoomTemp)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card summary-card-sensor">
                <div class="summary-label">Room Humidity</div>
                <div class="summary-value">@FmtPct(periodSummary?.AvgRoomHumidity)</div>
                <div class="summary-range">@FmtPct(periodSummary?.MinRoomHumidity) – @FmtPct(periodSummary?.MaxRoomHumidity)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card summary-card-sensor">
                <div class="summary-label">Hot Water</div>
                <div class="summary-value">@FmtTemp(periodSummary?.AvgHotWaterSetpoint)</div>
                <div class="summary-range">@FmtTemp(periodSummary?.MinHotWaterSetpoint) – @FmtTemp(periodSummary?.MaxHotWaterSetpoint)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="summary-card summary-card-sensor">
                <div class="summary-label">Flow Temp</div>
                <div class="summary-value">@FmtTemp(periodSummary?.AvgFlowTemp)</div>
                <div class="summary-range">@FmtTemp(periodSummary?.MinFlowTemp) – @FmtTemp(periodSummary?.MaxFlowTemp)</div>
            </div>
        </div>
    </div>

    <!-- ═══ DUTY CYCLE BAR ═══ -->
    @if (periodSummary?.SnapshotCount > 0)
    {
        <div class="row g-2 mb-3">
            <div class="col-6">
                <div class="summary-card summary-card-sensor">
                    <div class="summary-label">Heating Duty Cycle</div>
                    <div class="summary-value">@periodSummary.HeatingDutyCyclePercent.ToString("F1")%</div>
                </div>
            </div>
            <div class="col-6">
                <div class="summary-card summary-card-sensor">
                    <div class="summary-label">Hot Water Duty Cycle</div>
                    <div class="summary-value">@periodSummary.HotWaterDutyCyclePercent.ToString("F1")%</div>
                </div>
            </div>
        </div>
    }

    <!-- ═══ COP TREND CHART ═══ -->
    @if (trendSnapshots.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong>COP Trend — @PeriodLabel</strong>
                <span class="small text-muted ms-2">@trendSnapshots.Count data points</span>
            </div>
            <div class="card-body p-2">
                <RadzenChart Style="height: 200px;">
                    <RadzenLineSeries Data="@trendSnapshots" CategoryProperty="SnapshotTakenAt" ValueProperty="CoefficientOfPerformance"
                                     Stroke="rgb(40,167,69)" StrokeWidth="2" />
                    <RadzenLineSeries Data="@cop3RefLine" CategoryProperty="Time" ValueProperty="Value"
                                     Stroke="rgba(220,53,69,0.4)" StrokeWidth="1" LineType="LineType.Dashed" />
                    <RadzenCategoryAxis FormatString="@TrendAxisFormat" Visible="true" />
                    <RadzenValueAxis Min="0" Visible="true">
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="false" />
                </RadzenChart>
            </div>
        </div>
    }
    else if (!periodLoading && periodSummary != null)
    {
        <div class="alert alert-info">No snapshot data available for this period.</div>
    }

    <!-- ═══ AI SUMMARY ═══ -->
    <div class="ai-summary-card">
        <div class="ai-summary-header">
            <span class="ai-summary-title">AI Performance Summary</span>
            <div>
                @if (aiSummary is not null && aiSummary.GeneratedAt != default)
                {
                    <span class="small text-muted me-2">@aiSummary.GeneratedAt.ToString("dd MMM HH:mm")</span>
                }
                <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAiSummary" disabled="@aiLoading">
                    @(aiLoading ? "Generating..." : "Refresh")
                </button>
            </div>
        </div>

        @if (aiLoading && aiSummary == null)
        {
            <div class="d-flex align-items-center p-3">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                <span class="text-muted">Generating AI summary...</span>
            </div>
        }
        else if (aiSummary != null && !string.IsNullOrEmpty(aiSummary.WeekSummary))
        {
            <div class="ai-summary-body">
                @if (!string.IsNullOrEmpty(aiSummary.WeekSummary))
                {
                    <div class="ai-section">
                        <div class="ai-section-label">Last 7 Days</div>
                        <div class="ai-section-text">@aiSummary.WeekSummary</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(aiSummary.MonthSummary))
                {
                    <div class="ai-section">
                        <div class="ai-section-label">Last 30 Days</div>
                        <div class="ai-section-text">@aiSummary.MonthSummary</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(aiSummary.YearSummary))
                {
                    <div class="ai-section">
                        <div class="ai-section-label">Last 12 Months</div>
                        <div class="ai-section-text">@aiSummary.YearSummary</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(aiSummary.Suggestions))
                {
                    <div class="ai-section ai-suggestions">
                        <div class="ai-section-label">Suggestions</div>
                        <div class="ai-section-text">@aiSummary.Suggestions</div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ═══ TABBED DETAIL AREA ═══ -->
    <RadzenTabs @bind-SelectedIndex="selectedTab" Style="margin-top: 0.5rem;">
        <Tabs>
            <RadzenTabsItem Text="Performance & History" Icon="show_chart">
                @if (selectedTab == 0)
                {
                    <PerformanceTab DeviceId="@deviceId" AccountNumber="@accountNumber" Euid="@euid" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Comfort & System" Icon="home">
                @if (selectedTab == 1)
                {
                    <ComfortTab Summary="@summary" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Analysis" Icon="insights">
                @if (selectedTab == 2)
                {
                    <AnalysisTab DeviceId="@deviceId" />
                }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Costs" Icon="payments">
                @if (selectedTab == 3)
                {
                    <CostsTab AccountNumber="@accountNumber" />
                }
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@code {
    private string accountNumber = "";
    private string? deviceId;
    private string? euid;
    private bool isSetup;
    private bool isLoading;
    private string? errorMessage;
    private HeatPumpSummaryDto? summary;
    private LatestSnapshotDto? latestSnapshot;
    private int selectedTab;

    // AI Summary
    private AiSummaryDto? aiSummary;
    private bool aiLoading;

    // Period summary
    private PeriodSummaryDto? periodSummary;
    private bool periodLoading;
    private int selectedPeriodDays = 7;
    private int _periodLoadVersion;

    // Trend chart
    private List<HeatPumpSnapshotDto> trendSnapshots = [];
    private List<RefPoint> cop3RefLine = [];

    // Auto-refresh timer
    private System.Threading.Timer? _refreshTimer;

    // COP parsing (live)
    private double? _parsedCop;
    private string CopDisplay => _parsedCop.HasValue ? _parsedCop.Value.ToString("F2") : "—";
    private string CopColorClass => _parsedCop switch
    {
        >= 3.5 => "cop-green",
        >= 2.5 => "cop-amber",
        _ when _parsedCop.HasValue => "cop-red",
        _ => ""
    };

    // Period COP color
    private string PeriodCopColorClass => periodSummary?.AvgCop switch
    {
        >= 3.5 => "cop-green",
        >= 2.5 => "cop-amber",
        _ when periodSummary?.AvgCop.HasValue == true => "cop-red",
        _ => ""
    };

    private string PeriodLabel => selectedPeriodDays switch
    {
        1 => "Last 24 Hours",
        7 => "Last 7 Days",
        30 => "Last 30 Days",
        365 => "Last 12 Months",
        _ => $"Last {selectedPeriodDays} Days"
    };

    private string TrendAxisFormat => selectedPeriodDays <= 1 ? "{0:HH:mm}" : selectedPeriodDays <= 7 ? "{0:ddd HH:mm}" : "{0:MMM dd}";

    private string SnapshotHealthBadge
    {
        get
        {
            if (latestSnapshot?.HasData != true) return "bg-warning text-dark";
            var mins = latestSnapshot.MinutesAgo ?? double.MaxValue;
            if (mins < 20) return "bg-success";
            if (mins < 60) return "bg-warning text-dark";
            return "bg-danger";
        }
    }

    private string SnapshotHealthText
    {
        get
        {
            if (latestSnapshot?.HasData != true) return "No snapshots";
            var mins = (int)(latestSnapshot.MinutesAgo ?? 0);
            if (mins < 20) return "Healthy";
            if (mins < 60) return $"Delayed ({mins}m)";
            return $"Stale ({mins}m)";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAndDevice();
        if (isSetup)
        {
            await RefreshDashboard();
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    await RefreshLiveData();
                    await InvokeAsync(StateHasChanged);
                }
                catch { }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
    }

    private async Task LoadSettingsAndDevice()
    {
        try
        {
            var settings = await Api.GetSettingsAsync();
            var current = settings.FirstOrDefault();
            if (!string.IsNullOrWhiteSpace(current?.AccountNumber))
                accountNumber = current.AccountNumber;

            var devices = await Api.GetDevicesAsync();
            if (devices.Length > 0)
            {
                accountNumber = devices[0].AccountNumber;
                deviceId = devices[0].DeviceId;
                euid = devices[0].Euid;
                isSetup = true;
            }
        }
        catch (Exception ex) { errorMessage = $"Failed to load: {ex.Message}"; }
    }

    private async Task SetupDevice()
    {
        if (string.IsNullOrWhiteSpace(accountNumber))
        { errorMessage = "Save account settings first."; return; }
        isLoading = true; errorMessage = null;
        try
        {
            var result = await Api.SetupDeviceAsync(accountNumber);
            deviceId = result?.DeviceId; euid = result?.Euid; isSetup = true;
            await RefreshDashboard();
        }
        catch (Exception ex) { errorMessage = $"Setup failed: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task RefreshDashboard()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        isLoading = true;
        try
        {
            var summaryTask = Api.GetSummaryAsync(deviceId);
            var latestTask = Api.GetLatestSnapshotAsync(deviceId);
            await Task.WhenAll(summaryTask, latestTask);

            summary = summaryTask.Result;
            latestSnapshot = latestTask.Result;
            ParseCop();

            // Load period data and AI summary in parallel (don't block main dashboard)
            _ = LoadPeriodDataAsync();
            _ = LoadAiSummaryAsync();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    private async Task SetPeriod(int days)
    {
        selectedPeriodDays = days;
        await LoadPeriodDataAsync();
    }

    private async Task LoadPeriodDataAsync()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        var thisVersion = Interlocked.Increment(ref _periodLoadVersion);
        periodLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var from = DateTime.UtcNow.AddDays(-selectedPeriodDays);
            var to = DateTime.UtcNow;

            var periodTask = Api.GetPeriodSummaryAsync(deviceId, from, to);
            var snapshotsTask = Api.GetSnapshotsAsync(deviceId, from, to);
            await Task.WhenAll(periodTask, snapshotsTask);

            // Discard results if a newer request was started while we were loading
            if (thisVersion != _periodLoadVersion) return;

            periodSummary = periodTask.Result;
            var allSnapshots = snapshotsTask.Result?.Snapshots?.OrderBy(s => s.SnapshotTakenAt).ToList() ?? [];

            // Downsample for long periods to keep chart responsive
            trendSnapshots = selectedPeriodDays > 7 ? DownsampleSnapshots(allSnapshots, maxPoints: 500) : allSnapshots;
            BuildCop3RefLine();
        }
        catch (Exception ex)
        {
            if (thisVersion == _periodLoadVersion)
                errorMessage = $"Period data failed: {ex.Message}";
        }
        finally
        {
            if (thisVersion == _periodLoadVersion)
            {
                periodLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static List<HeatPumpSnapshotDto> DownsampleSnapshots(List<HeatPumpSnapshotDto> snapshots, int maxPoints)
    {
        if (snapshots.Count <= maxPoints) return snapshots;
        var step = (double)snapshots.Count / maxPoints;
        var result = new List<HeatPumpSnapshotDto>(maxPoints);
        for (var i = 0; i < maxPoints; i++)
            result.Add(snapshots[(int)(i * step)]);
        return result;
    }

    private async Task RefreshLiveData()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        try
        {
            summary = await Api.GetSummaryAsync(deviceId);
            latestSnapshot = await Api.GetLatestSnapshotAsync(deviceId);
            ParseCop();
        }
        catch { }
    }

    private void ParseCop()
    {
        _parsedCop = null;
        if (summary?.LivePerformance?.CoefficientOfPerformance != null
            && double.TryParse(summary.LivePerformance.CoefficientOfPerformance, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var cop))
        {
            _parsedCop = cop;
        }
    }

    private void BuildCop3RefLine()
    {
        if (trendSnapshots.Count < 2) { cop3RefLine = []; return; }
        cop3RefLine =
        [
            new RefPoint { Time = trendSnapshots.First().SnapshotTakenAt, Value = 3.0m },
            new RefPoint { Time = trendSnapshots.Last().SnapshotTakenAt, Value = 3.0m }
        ];
    }

    private async Task LoadAiSummaryAsync()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        aiLoading = true;
        await InvokeAsync(StateHasChanged);
        try { aiSummary = await Api.GetAiSummaryAsync(deviceId); }
        catch { }
        finally { aiLoading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task RefreshAiSummary()
    {
        if (string.IsNullOrEmpty(deviceId)) return;
        aiLoading = true;
        try { aiSummary = await Api.RefreshAiSummaryAsync(deviceId); }
        catch (Exception ex) { errorMessage = $"AI refresh failed: {ex.Message}"; }
        finally { aiLoading = false; }
    }

    private static string FmtDec(double? v) => v.HasValue ? v.Value.ToString("F2") : "—";
    private static string FmtTemp(double? v) => v.HasValue ? $"{v.Value:F1} °C" : "—";
    private static string FmtPct(double? v) => v.HasValue ? $"{v.Value:F1}%" : "—";
    private static string FmtKwh(double? v) => v.HasValue ? $"{v.Value:F1}" : "—";

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private sealed class RefPoint
    {
        public DateTime Time { get; set; }
        public decimal Value { get; set; }
    }
}
