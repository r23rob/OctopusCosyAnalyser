# Copy this to .env.local and fill in your values.
# Used during local Vite dev server (without Aspire).
# When using Aspire (AppHost), these are injected automatically.

# The URL of the .NET API service.
# Default dev profile is https — run `dotnet dev-certs https --trust` once
# to make the cert browser- and Node-trusted (the Vite proxy uses secure:false
# so it'll work either way, but the browser still needs to trust the cert).
VITE_API_TARGET=https://localhost:7558

# Port for the Vite dev server (Aspire will override this)
# VITE_PORT=5173
