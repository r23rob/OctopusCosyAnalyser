# Copy this to .env.local and fill in your values.
# Used during local Vite dev server (without Aspire).
# When using Aspire (AppHost), these are injected automatically.

# The URL of the .NET API service
VITE_API_TARGET=http://localhost:5236

# Port for the Vite dev server (Aspire will override this)
# VITE_PORT=5173
